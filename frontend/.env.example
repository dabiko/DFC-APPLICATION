# ===================================
# API Configuration
# ===================================
VITE_API_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000

# ===================================
# Application Configuration
# ===================================
VITE_APP_NAME=Digital Filing Cabinet
VITE_APP_VERSION=1.0.0

# ===================================
# Feature Flags
