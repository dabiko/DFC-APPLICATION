# ===================================
# Dependencies (NEVER include in build)
# ===================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnp/
.pnp.js

# ===================================
# Build output (built during image creation)
# ===================================
dist/
build/
.vite/
.turbo/
out/

# ===================================
# Testing & Coverage
# ===================================
coverage/
.nyc_output/
cypress/videos/
cypress/screenshots/
tests/e2e/videos/
tests/e2e/screenshots/
.vitest/

# ===================================
# IDE & Editor files
# ===================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# ===================================
# OS files
# ===================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.lnk

# ===================================
# Git files
# ===================================
.git/
.gitignore
.gitattributes
.github/

# ===================================
# Environment files (CRITICAL - NEVER include)
# ===================================
.env
.env.local
.env.*.local
.env.production.local
.env.staging.local
*.env

# ===================================
# Documentation (not needed in image)
# ===================================
*.md
README*
docs/
*.pdf

# ===================================
# Storybook
# ===================================
storybook-static/
.storybook-static/
*.storybook.log

# ===================================
# Cache & Temporary files
# ===================================
.cache/
.temp/
tmp/
*.cache
*.tmp
*.log

# ===================================
# TypeScript cache
# ===================================
*.tsbuildinfo
.tsbuildinfo

# ===================================
# Docker files (don't copy into image)
# ===================================
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore
nginx.conf
# Exception: Keep nginx.conf for production
!nginx.conf

# ===================================
# CI/CD files
# ===================================
.gitlab-ci.yml
.travis.yml
Jenkinsfile
.circleci/

# ===================================
# Development scripts
# ===================================
scripts/
fixtures/

# ===================================
# Source maps (optional - uncomment to exclude)
# ===================================
# *.map
# dist/**/*.map

# ===================================
# Miscellaneous
# ===================================
.eslintcache
.stylelintcache
.vercel
.next/
.nuxt/
