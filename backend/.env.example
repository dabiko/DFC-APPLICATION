# ===================================
# Django Settings
# ===================================
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production-use-at-least-50-characters
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# ===================================
# Database Configuration
# ===================================
# Use these values for Docker PostgreSQL
DATABASE_URL=postgres://dfc_admin_user:dfc_password_2025@localhost:5432/dfc_database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=dfc_database
DB_USER=dfc_admin_user
DB_PASSWORD=your-database-password-here
DB_HOST=127.0.0.1
DB_PORT=5432

# ===================================
# MinIO Storage Configuration
# ===================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET_NAME=dfc-documents
MINIO_USE_SSL=False

# ===================================
# Elasticsearch Configuration
# ===================================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USE_SSL=False

# ===================================
# Redis Configuration
# ===================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ===================================
# Celery Configuration
# ===================================
CELERY_BROKER_URL=amqp://dfc_rabbit:dfc_rabbit_password_2025@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ===================================
# Security Settings
# ===================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===================================
# JWT Settings
# ===================================
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ===================================
# Email Configuration
# ===================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=noreply@digitalfilingcabinet.com
FRONTEND_URL=http://localhost:5173

# ===================================
# Sentry (Error Tracking) - Optional
# ===================================
SENTRY_DSN=

# ===================================
# Environment
# ===================================
ENVIRONMENT=development
